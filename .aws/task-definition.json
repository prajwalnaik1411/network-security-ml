{
  "family": "networksecurity",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::648513035545:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "networksecurity",
      "image": "648513035545.dkr.ecr.ap-south-1.amazonaws.com/networksecurity:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ]
    }
  ]
}